# Copy to .env and fill in real values. .env is gitignored.

# API key for the market-data provider (e.g. Polygon.io)
SQUEEZE_API_KEY=your_api_key_here

# Base URL for the provider. Defaults to Polygon.io if unset.
SQUEEZE_BASE_URL=https://api.polygon.io

# Optional: how many parallel requests to make against the API
SQUEEZE_MAX_WORKERS=4

# Optional: where to drop scan output CSVs
SQUEEZE_OUTPUT_DIR=out
